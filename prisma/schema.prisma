// Integrated Allergy IMS - Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Patient {
  id              String    @id @default(cuid())
  name            String
  dob             DateTime
  patientId       String    @unique
  physician       String
  clinicLocation  String
  diagnosis       String
  startDate       DateTime
  phone           String?
  email           String?
  insuranceId     String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  doctorId        String?
  doctor          Doctor?   @relation(fields: [doctorId], references: [id])

  allergenMixes   AllergenMix[]
  vials           Vial[]
  dosingSchedules DosingSchedule[]
  auditLogs       AuditLog[]
  appointments    Appointment[]
}

model Doctor {
  id             String    @id @default(cuid())
  name           String
  title          String    @default("MD")
  specialty      String    @default("Allergy & Immunology")
  email          String?
  phone          String?
  clinicLocation String?
  npi            String?
  photoUrl       String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  patients       Patient[]
}

model Allergen {
  id           String    @id @default(cuid())
  name         String
  type         String    // mold, pollen, dust, animal, food, insect
  manufacturer String?
  lotNumber    String?
  stockConc    String?   // e.g. "1:10"
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  mixes        AllergenMix[]
}

model AllergenMix {
  id         String    @id @default(cuid())
  patientId  String
  allergenId String
  volumeMl   Float
  deletedAt  DateTime?

  patient    Patient  @relation(fields: [patientId], references: [id])
  allergen   Allergen @relation(fields: [allergenId], references: [id])
}

model Vial {
  id              String    @id @default(cuid())
  patientId       String
  vialNumber      Int       // 1-4
  dilutionRatio   String    // e.g. "1:10000"
  totalVolumeMl   Float
  glycerinPercent Float
  colorCode       String    // silver, blue, yellow, red
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  patient         Patient          @relation(fields: [patientId], references: [id])
  doses           DosingSchedule[]
}

model DosingSchedule {
  id             String    @id @default(cuid())
  patientId      String
  vialId         String
  weekNumber     Int
  doseMl         Float
  phase          String    // buildup, maintenance
  reaction       String?
  notes          String?
  administered   Boolean   @default(false)
  administeredAt DateTime?
  deletedAt      DateTime?

  patient        Patient @relation(fields: [patientId], references: [id])
  vial           Vial    @relation(fields: [vialId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  patientId String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  patient   Patient? @relation(fields: [patientId], references: [id])
}

model Appointment {
  id          String    @id @default(cuid())
  patientId   String
  type        String    // shot, skin_test, evaluation, follow_up, other
  title       String
  startTime   DateTime
  endTime     DateTime
  provider    String?
  notes       String?
  status      String    @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  patient     Patient  @relation(fields: [patientId], references: [id])
}

model Nurse {
  id             String    @id @default(cuid())
  name           String
  title          String    @default("RN")
  email          String?
  phone          String?
  clinicLocation String?
  npi            String?
  photoUrl       String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}
