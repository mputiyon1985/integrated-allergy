// Integrated Allergy IMS - Prisma Schema
// https://pris.ly/d/prisma-schema
//
// Data model for the Integrated Allergy Practice Management System.
// All clinical records use soft-delete (deletedAt timestamp) to preserve
// audit history. Hard deletes are never performed on patient-linked data.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Top-level organizational unit (practice group, hospital system, or independent clinic).
/// All users, locations, patients, doctors, and nurses belong to a BusinessEntity.
/// Supports multi-tenant deployments where multiple practices share the same database.
/// Soft-deleted via deletedAt; active flag controls visibility in dropdowns.
model BusinessEntity {
  id           String           @id @default(cuid())
  name         String
  ein          String?
  phone        String?
  email        String?
  website      String?
  logo         String?
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  deletedAt    DateTime?
  users        AppUser[]
  locations    ClinicLocation[]
  patients     Patient[]
  doctors      Doctor[]
  nurses       Nurse[]
  appointments Appointment[]
}

/// Application user account (staff, physician, nurse, or super admin).
/// Roles: super_admin | entity_admin | location_staff | doctor | nurse.
/// MFA is enforced via speakeasy TOTP; mfaSecret is stored encrypted at rest by Turso.
/// Users are soft-deleted (deletedAt) rather than hard-deleted to preserve audit history.
/// doctorId / nurseId link the account to a clinical staff record for identity display.
model AppUser {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String
  name           String
  role           String               @default("location_staff")
  entityId       String?
  entity         BusinessEntity?      @relation(fields: [entityId], references: [id])
  mfaSecret      String?
  mfaEnabled     Boolean              @default(false)
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  deletedAt      DateTime?
  doctorId       String?
  nurseId        String?
  locationAccess UserLocationAccess[]
}

/// Junction table granting a user access to a specific clinic location.
/// location_staff role users may only access locations listed here.
/// entity_admin and super_admin bypass this table — they access all locations.
model UserLocationAccess {
  id         String         @id @default(cuid())
  userId     String
  locationId String
  user       AppUser        @relation(fields: [userId], references: [id])
  location   ClinicLocation @relation(fields: [locationId], references: [id])
  createdAt  DateTime       @default(now())
}

/// Core patient record for an individual enrolled in allergen immunotherapy.
/// patientId is a human-readable identifier (e.g., PA-XXXXXXXX) auto-generated on creation.
/// status progresses through: build-up → maintenance → complete (or inactive).
/// Soft-deleted via deletedAt; all related allergens, vials, and schedules are preserved.
/// Linked to Doctor for physician assignment; entity scoping is via entityId.
model Patient {
  id             String    @id @default(cuid())
  name           String
  dob            DateTime
  patientId      String    @unique
  physician      String
  clinicLocation String
  diagnosis      String
  startDate      DateTime
  phone          String?
  email          String?
  insuranceId    String?
  notes          String?
  status         String    @default("build-up")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  doctorId       String?
  doctor         Doctor?   @relation(fields: [doctorId], references: [id])
  entityId       String?
  entity         BusinessEntity? @relation(fields: [entityId], references: [id])

  allergenMixes   AllergenMix[]
  vials           Vial[]
  dosingSchedules DosingSchedule[]
  auditLogs       AuditLog[]
  appointments    Appointment[]
}

/// Physician record representing a doctor at the clinic.
/// Linked to Patient (one doctor → many patients) and optionally to AppUser
/// for login account linkage. npi is the National Provider Identifier.
/// Soft-deleted with active flag; patients retain doctorId even after doctor soft-delete.
model Doctor {
  id             String          @id @default(cuid())
  name           String
  title          String          @default("MD")
  specialty      String          @default("Allergy & Immunology")
  email          String?
  phone          String?
  clinicLocation String?
  npi            String?
  photoUrl       String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  entityId       String?
  appUserId      String?
  entity         BusinessEntity? @relation(fields: [entityId], references: [id])

  patients Patient[]
}

/// Master allergen extract record representing a single antigen in the clinic's library.
/// Types: mold | pollen | dust | animal | food | insect.
/// stockConc is the stock concentration (e.g., "1:10" or "10,000 AU/mL").
/// Allergens are added to patient-specific AllergenMix records for vial compounding.
model Allergen {
  id           String    @id @default(cuid())
  name         String
  type         String // mold, pollen, dust, animal, food, insect
  manufacturer String?
  lotNumber    String?
  stockConc    String? // e.g. "1:10"
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  mixes AllergenMix[]
}

/// Junction record linking a patient to a specific allergen with a prescribed volume.
/// Represents one component of the patient's custom allergen extract formulation.
/// volumeMl is the per-allergen volume added to the compounded vial series.
/// Soft-deleted via deletedAt; safety validation runs against the full active mix.
model AllergenMix {
  id         String    @id @default(cuid())
  patientId  String
  allergenId String
  volumeMl   Float
  deletedAt  DateTime?

  patient  Patient  @relation(fields: [patientId], references: [id])
  allergen Allergen @relation(fields: [allergenId], references: [id])
}

/// Compounded allergen extract vial for a patient following the AAAI 4-vial dilution series.
/// vialNumber 1–4 maps to: 1=Silver (1:10,000), 2=Blue (1:1,000), 3=Yellow (1:100), 4=Red (1:10).
/// glycerinPercent must not exceed 50% per USP 797; standard clinical practice uses 10%.
/// expiresAt is set to 90 days from compounding. colorCode drives visual display in the UI.
model Vial {
  id              String    @id @default(cuid())
  patientId       String
  vialNumber      Int // 1-4
  dilutionRatio   String // e.g. "1:10000"
  totalVolumeMl   Float
  glycerinPercent Float
  colorCode       String // silver, blue, yellow, red
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  patient Patient          @relation(fields: [patientId], references: [id])
  doses   DosingSchedule[]
}

/// Weekly injection dose record in a patient's immunotherapy buildup or maintenance schedule.
/// weekNumber is sequential across the full treatment course (1–40+ weeks).
/// phase: 'buildup' | 'maintenance'.
/// administered is set true after the injection is given; administeredAt records exact time.
/// reaction and notes capture clinical observations at the time of injection.
model DosingSchedule {
  id             String    @id @default(cuid())
  patientId      String
  vialId         String
  weekNumber     Int
  doseMl         Float
  phase          String // buildup, maintenance
  reaction       String?
  notes          String?
  administered   Boolean   @default(false)
  administeredAt DateTime?
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])
  vial    Vial    @relation(fields: [vialId], references: [id])
}

/// Immutable audit trail entry for every create/update/delete action in the system.
/// Written by all API routes after mutations; never updated or deleted.
/// entity identifies the table/model affected (e.g., 'Patient', 'Vial', 'AppUser').
/// patientId links the event to a patient when relevant, enabling per-patient audit history.
/// Used for regulatory compliance, accreditation, and clinical accountability.
model AuditLog {
  id        String   @id @default(cuid())
  patientId String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  patient Patient? @relation(fields: [patientId], references: [id])
}

/// Scheduled clinical appointment for a patient.
/// type: shot | skin_test | evaluation | follow_up | other.
/// status lifecycle: scheduled → confirmed → completed | cancelled | no_show.
/// Soft-deleted via deletedAt; cancellations should set status='cancelled' rather than delete.
/// entityId scopes the appointment to a business entity.
model Appointment {
  id        String    @id @default(cuid())
  patientId String
  type      String // shot, skin_test, evaluation, follow_up, other
  title     String
  startTime DateTime
  endTime   DateTime
  provider  String?
  notes     String?
  status    String    @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  entityId  String?
  entity    BusinessEntity? @relation(fields: [entityId], references: [id])

  patient Patient @relation(fields: [patientId], references: [id])
}

/// Nursing or clinical support staff record (RN, LPN, MA, CMA, NP).
/// Mirrors the Doctor model structure. npi is the National Provider Identifier (optional for MAs).
/// Linked to AppUser via appUserId for login account association.
/// Soft-deleted with active flag to preserve patient record history.
model Nurse {
  id             String          @id @default(cuid())
  name           String
  title          String          @default("RN")
  email          String?
  phone          String?
  clinicLocation String?
  npi            String?
  photoUrl       String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  entityId       String?
  appUserId      String?
  entity         BusinessEntity? @relation(fields: [entityId], references: [id])
}

/// Physical clinic location or branch office within a BusinessEntity.
/// Used for patient assignment and user location-based access control.
/// sortOrder controls display order in dropdowns (lower = first).
/// Soft-deleted via deletedAt; UserLocationAccess records persist after deletion.
model ClinicLocation {
  id             String               @id @default(cuid())
  name           String
  address        String?
  phone          String?
  active         Boolean              @default(true)
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  deletedAt      DateTime?
  entityId       String?
  entity         BusinessEntity?      @relation(fields: [entityId], references: [id])
  userAccess     UserLocationAccess[]
}

/// Configurable list of diagnosis codes shown in patient enrollment forms.
/// icdCode stores the ICD-10 code (e.g., "J30.1" for allergic rhinitis).
/// sortOrder controls dropdown display order. Managed via Settings → Diagnoses admin panel.
model DiagnosisOption {
  id        String    @id @default(cuid())
  name      String
  icdCode   String?
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

/// Configurable list of physician credential titles (MD, DO, PhD, etc.).
/// Shown in doctor creation forms. Managed via Settings admin panel.
model DoctorTitle {
  id        String    @id @default(cuid())
  name      String
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

/// Configurable list of nursing credential titles (RN, LPN, MA, CMA, NP, etc.).
/// Shown in nurse creation forms. Managed via Settings admin panel.
model NurseTitle {
  id        String    @id @default(cuid())
  name      String
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

/// Pre-computed dashboard statistics singleton — updated whenever source tables change.
/// Dashboard API reads this single row instead of running 11 live COUNT queries per request.
/// The id is always 'singleton'; upserted via ON CONFLICT in refreshDashboardStats().
model DashboardStats {
  id                  String   @id @default("singleton")
  totalPatients       Int      @default(0)
  activeTreatments    Int      @default(0)
  vialsExpiringSoon   Int      @default(0)
  vialsExpiring7Days  Int      @default(0)
  dosesThisWeek       Int      @default(0)
  shotsToday          Int      @default(0)
  testsToday          Int      @default(0)
  evalsToday          Int      @default(0)
  activeDoctors       Int      @default(0)
  activeNurses        Int      @default(0)
  updatedAt           DateTime @updatedAt
}
