# ============================================================
# Integrated Allergy IMS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Database — Turso (production) or local SQLite (development)
# ------------------------------------------------------------

# Production: Turso libSQL
# Get your URL from: https://turso.tech → your database → Connect
DATABASE_URL=libsql://your-db-name.turso.io

# Production: Turso authentication token
# Get your token from: Turso dashboard → Tokens
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Local SQLite (development only — uncomment and use instead of Turso):
# DATABASE_URL=file:./prisma/dev.db
# DATABASE_AUTH_TOKEN=

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------

# JWT signing secret — generate with: openssl rand -base64 32
# HIPAA: Use a strong random secret; rotate periodically.
JWT_SECRET=your-jwt-secret-here

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

NODE_ENV=development
